<Application
    x:Class="VoiceControlApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceControlApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Custom themes and styles -->
                <ResourceDictionary>
                    <!-- Fluent Design System Colors -->
                    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
                    <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#40E0FF"/>
                    <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="#99EBFF"/>
                    <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#005A9E"/>
                    <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#004578"/>
                    
                    <!-- Custom Fluent styles -->
                    <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="28"/>
                        <Setter Property="FontWeight" Value="SemiLight"/>
                        <Setter Property="Margin" Value="0,0,0,16"/>
                    </Style>
                    
                    <Style x:Key="SubheaderTextBlockStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="20"/>
                        <Setter Property="FontWeight" Value="SemiLight"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                    </Style>
                    
                    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Padding" Value="32,8"/>
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>