<Window
    x:Class="VoiceControlApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceControlApp"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Acrylic Background for Fluent Design -->
        <Grid.Background>
            <AcrylicBrush TintColor="{ThemeResource SystemControlBackgroundAltHighBrush}" 
                         TintOpacity="0.8" 
                         BackgroundSource="HostBackdrop"/>
        </Grid.Background>
        
        <ScrollViewer>
            <StackPanel Margin="32" Spacing="24">
                
                <!-- Header Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="🎤 Voice Control System" 
                               Style="{StaticResource HeaderTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="AI-Powered Robot Command Interface with Fluent Design" 
                               Style="{StaticResource SubheaderTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Status Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="System Status" FontWeight="SemiBold" FontSize="16"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Status:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" 
                                          FontWeight="SemiBold"
                                          Foreground="{x:Bind ViewModel.StatusColor, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Last Command" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{x:Bind ViewModel.LastCommand, Mode=OneWay}" 
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Control Panel -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Text="Voice Control" FontWeight="SemiBold" FontSize="18"/>
                        
                        <!-- Main Control Button -->
                        <Button x:Name="ListenButton"
                                Content="{x:Bind ViewModel.ListenButtonText, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleListeningCommand}"
                                HorizontalAlignment="Center"
                                Style="{StaticResource AccentButtonStyle}"
                                FontSize="18"
                                Padding="48,16">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0"/>
                                    <GradientStop Color="{ThemeResource SystemAccentColorLight1}" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        
                        <!-- Settings and File Controls -->
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Center" 
                                   Spacing="12">
                            <Button Content="⚙️ Settings" 
                                   Command="{x:Bind ViewModel.ShowSettingsCommand}"
                                   Style="{StaticResource DefaultButtonStyle}"/>
                            <Button Content="📁 Open Output" 
                                   Command="{x:Bind ViewModel.OpenOutputFileCommand}"
                                   Style="{StaticResource DefaultButtonStyle}"/>
                            <Button Content="🔄 Clear Log" 
                                   Command="{x:Bind ViewModel.ClearLogCommand}"
                                   Style="{StaticResource DefaultButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Audio Visualization -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Visibility="{x:Bind ViewModel.IsListening, Mode=OneWay}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Text="🎵 Live Audio Spectrum" FontWeight="SemiBold" FontSize="16"/>
                        
                        <!-- Audio Spectrum Visualization Canvas -->
                        <Border Height="120" 
                               Background="{ThemeResource SurfaceStrokeColorFlyoutBrush}"
                               CornerRadius="4">
                            <Canvas x:Name="AudioSpectrumCanvas" Background="Transparent">
                                <!-- Audio visualization bars will be added programmatically -->
                            </Canvas>
                        </Border>
                        
                        <!-- Recording Timer -->
                        <TextBlock Text="{x:Bind ViewModel.RecordingTimer, Mode=OneWay}" 
                                  HorizontalAlignment="Center"
                                  FontSize="14"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Live Transcription -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Text="💬 Live Transcription" FontWeight="SemiBold" FontSize="16"/>
                        
                        <ScrollViewer Height="200" 
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{ThemeResource ControlFillColorInputActiveBrush}"
                                     CornerRadius="4"
                                     Padding="16">
                            <TextBlock Text="{x:Bind ViewModel.TranscriptionText, Mode=OneWay}"
                                      TextWrapping="Wrap"
                                      FontFamily="Consolas"
                                      FontSize="14"
                                      LineHeight="20"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Activity Log -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Text="📋 Activity Log" FontWeight="SemiBold" FontSize="16"/>
                        
                        <ScrollViewer Height="180" 
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{ThemeResource ControlFillColorInputActiveBrush}"
                                     CornerRadius="4"
                                     Padding="16">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.ActivityLog, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                  FontFamily="Consolas"
                                                  FontSize="12"
                                                  Margin="0,2"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Supported Commands Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="24"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Text="🎯 Supported Commands" FontWeight="SemiBold" FontSize="16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="System Controls:" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="• open main" FontSize="11"/>
                                <TextBlock Text="• open robot" FontSize="11"/>
                                <TextBlock Text="• open lamp" FontSize="11"/>
                                <TextBlock Text="• alarm" FontSize="11"/>
                                <TextBlock Text="• open robot cell" FontSize="11"/>
                                <TextBlock Text="• open 1, open 2" FontSize="11"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Applications:" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="• open train" FontSize="11"/>
                                <TextBlock Text="• open report" FontSize="11"/>
                                <TextBlock Text="• open record" FontSize="11"/>
                                <TextBlock Text="• open user admin" FontSize="11"/>
                                <TextBlock Text="• open user logging" FontSize="11"/>
                                <TextBlock Text="• open user log" FontSize="11"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Templates & Cameras:" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="• camera 1-4 (open/close)" FontSize="11"/>
                                <TextBlock Text="• template A-F" FontSize="11"/>
                                <TextBlock Text="• template 7-10" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>